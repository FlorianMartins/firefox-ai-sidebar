{
  "manifest_version": 3,
  "name": "AI Sidebar — Claude & OpenRouter",
  "version": "0.1.0",
  "description": "Une sidebar IA qui discute avec Claude et OpenRouter, lit la page et les onglets, et agit dans le navigateur (mode agent). BYOK : vos clés API restent locales.",
  "author": "Florian Martins",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-sidebar@behivey.com",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["src/background/background.js"],
    "type": "module"
  },
  "sidebar_action": {
    "default_title": "AI Sidebar",
    "default_panel": "src/sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      }
    }
  }
}
